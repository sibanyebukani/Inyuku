{
  "name": "inyuku-api",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "openapi:check": "tsx scripts/openapi-drift.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3",
    "@fastify/cookie": "^11",
    "@fastify/cors": "^10",
    "@fastify/helmet": "^12",
    "@fastify/swagger": "^9",
    "@fastify/swagger-ui": "^5",
    "@prisma/client": "^6",
    "bcryptjs": "^2",
    "fastify": "^5",
    "fastify-type-provider-zod": "^4",
    "ioredis": "^5",
    "pino-pretty": "^13.1.3",
    "resend": "^4",
    "zod": "^3"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@types/bcryptjs": "^2",
    "@types/node": "^24",
    "eslint": "^9",
    "prisma": "^6",
    "tsx": "^4",
    "typescript": "~5.9",
    "typescript-eslint": "^8",
    "vitest": "^2"
  }
}
