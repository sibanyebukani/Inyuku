# Postgres 16 (EU)
DATABASE_URL=postgresql://inyuku:inyuku@localhost:5432/inyuku_dev

# Redis 7
REDIS_URL=redis://localhost:6379

# JWT secrets (generate with openssl rand -base64 32)
JWT_SECRET=
JWT_SECRET_PREVIOUS=
JWT_REFRESH_SECRET=

# At-rest encryption for secret Settings (32-byte base64)
ENCRYPTION_KEY=

# Signed-URL boundary for blobs (32-byte base64, separate from ENCRYPTION_KEY)
BLOB_SIGN_SECRET=

# Object storage: r2 | local
STORAGE_DRIVER=r2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_PUBLIC_BASE_URL=

# Cookie / CORS / proxy trust
COOKIE_DOMAIN=
# Dev origin first so browser UI can call the local API; prod wildcard last
CORS_ALLOWED_ORIGINS=http://localhost:3001,*.inyuku.co.za
# Number of trusted proxy hops (0 in dev; set to Railway/Cloudflare hop count in prod)
TRUSTED_PROXY_HOPS=0

# Where best-effort lead notifications are sent (optional)
LEAD_NOTIFICATION_EMAIL=

# Defense-in-depth global auth rate limit (requests per IP per minute)
AUTH_GLOBAL_LIMIT=30

# Email bootstrap fallback (live key normally in Settings)
RESEND_API_KEY=

# Observability
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
GIT_COMMIT_SHA=

# WhatsApp BSP (360dialog) plumbing
WHATSAPP_BSP_BASE_URL=https://waba.360dialog.io
WHATSAPP_INBOUND_DRAIN_INTERVAL_MS=1000

# Server port
PORT=8080
