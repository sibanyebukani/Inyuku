generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipRole {
  MERCHANT_OWNER
  MERCHANT_STAFF
  ADMIN
  SUPPORT
  AI_AGENT

  @@map("membership_role")
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING_DELETION

  @@map("user_status")
}

enum BusinessStatus {
  ACTIVE
  SUSPENDED

  @@map("business_status")
}

enum ConsentStatus {
  GRANTED
  REVOKED

  @@map("consent_status")
}

enum LeadSource {
  CONTACT
  IMPACT_REPORT
  SHARE_STORY

  @@map("lead_source")
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CLOSED
  SPAM

  @@map("lead_status")
}

model User {
  id                  String              @id @default(cuid()) @map("id")
  email               String              @unique @map("email")
  name                String              @map("name")
  phone               String?             @unique @map("phone")
  passwordHash        String              @map("password_hash")
  status              UserStatus          @default(ACTIVE) @map("status")
  failedAttempts      Int                 @default(0) @map("failed_attempts")
  lockedUntil         DateTime?           @map("locked_until")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  memberships         Membership[]
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  phoneOtps           PhoneOtp[]
  auditLogs           AuditLog[]
  consents            Consent[]
  aiUsages            AiUsage[]

  @@map("users")
}

model RefreshToken {
  id          String    @id @default(cuid()) @map("id")
  tokenHash   String    @unique @map("token_hash")
  userId      String    @map("user_id")
  familyId    String    @map("family_id")
  expiresAt   DateTime  @map("expires_at")
  revokedAt   DateTime? @map("revoked_at")
  replacedById String?  @map("replaced_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(cuid()) @map("id")
  userId    String    @map("user_id")
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model PhoneOtp {
  id         String    @id @default(cuid()) @map("id")
  userId     String?   @map("user_id")
  phone      String    @map("phone")
  purpose    String?   @map("purpose")
  codeHash   String    @map("code_hash")
  attempts   Int       @default(0) @map("attempts")
  expiresAt  DateTime  @map("expires_at")
  verifiedAt DateTime? @map("verified_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("phone_otps")
}

model Business {
  id        String         @id @default(cuid()) @map("id")
  name      String         @map("name")
  slug      String?        @unique @map("slug")
  status    BusinessStatus @default(ACTIVE) @map("status")
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  memberships     Membership[]
  consents        Consent[]
  aiUsages        AiUsage[]
  auditLogs       AuditLog[]
  errorLogs       ErrorLog[]
  permissions     Permission[]
  products        Product[]
  stockMovements  StockMovement[]
  orders          Order[]
  orderLines      OrderLine[]
  customers       Customer[]
  analyticsEvents AnalyticsEvent[]

  @@map("businesses")
}

model Membership {
  id         String         @id @default(cuid()) @map("id")
  userId     String         @map("user_id")
  businessId String         @map("business_id")
  role       MembershipRole @default(MERCHANT_STAFF) @map("role")
  permissions String[]      @map("permissions")
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
  @@map("memberships")
}

model Permission {
  id          String   @id @default(cuid()) @map("id")
  key         String   @unique @map("key")
  description String?  @map("description")
  businessId  String?  @map("business_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  business Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("permissions")
}

model AuditLog {
  id        String   @id @default(cuid()) @map("id")
  userId    String?  @map("user_id")
  businessId String? @map("business_id")
  action    String   @map("action")
  entity    String   @map("entity")
  entityId  String?  @map("entity_id")
  changes   Json?    @map("changes")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  business Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

model ErrorLog {
  id         String   @id @default(cuid()) @map("id")
  businessId String?  @map("business_id")
  code       String   @map("code")
  message    String   @map("message")
  stack      String?  @map("stack")
  context    Json?    @map("context")
  commitSha  String?  @map("commit_sha")
  createdAt  DateTime @default(now()) @map("created_at")

  business Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)

  @@map("error_logs")
}

model Setting {
  id        String   @id @default(cuid()) @map("id")
  key       String   @map("key")
  value     String   @map("value")
  isSecret  Boolean  @default(false) @map("is_secret")
  businessId String  @map("business_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([key, businessId])
  @@map("settings")
}

model Consent {
  id        String        @id @default(cuid()) @map("id")
  businessId String       @map("business_id")
  userId    String?       @map("user_id")
  purpose   String        @map("purpose")
  status    ConsentStatus @default(GRANTED) @map("status")
  grantedAt DateTime      @default(now()) @map("granted_at")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  business     Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user         User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  revocations  ConsentRevocation[]
  customers    Customer[]

  @@map("consents")
}

model ConsentRevocation {
  id        String   @id @default(cuid()) @map("id")
  consentId String   @map("consent_id")
  reason    String?  @map("reason")
  createdAt DateTime @default(now()) @map("created_at")

  consent Consent @relation(fields: [consentId], references: [id], onDelete: Cascade)

  @@map("consent_revocations")
}

model AiUsage {
  id           String   @id @default(cuid()) @map("id")
  businessId   String   @map("business_id")
  userId       String?  @map("user_id")
  feature      String   @map("feature")
  tier         String   @map("tier")
  model        String   @map("model")
  inputTokens  Int?     @map("input_tokens")
  outputTokens Int?     @map("output_tokens")
  tokens       Int?     @map("tokens")
  costCents    Int      @default(0) @map("cost_cents")
  cacheHit     Boolean? @map("cache_hit")
  latencyMs    Int?     @map("latency_ms")
  requestId    String?  @map("request_id")
  createdAt    DateTime @default(now()) @map("created_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("ai_usage")
}

model Lead {
  id        String     @id @default(cuid()) @map("id")
  source    LeadSource @map("source")
  status    LeadStatus @default(NEW) @map("status")
  name      String?    @map("name")
  email     String?    @map("email")
  message   String?    @map("message")
  payload   Json?      @map("payload")
  ip        String?    @map("ip")
  ua        String?    @map("ua")
  consent   Boolean?   @map("consent")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@map("leads")
}

// ─── M2 Commerce Core ────────────────────────────────────────────────────────

enum ProductStatus {
  ACTIVE
  ARCHIVED

  @@map("product_status")
}

enum StockMovementType {
  OPENING
  ADJUSTMENT
  SALE
  SALE_REVERSAL
  RECEIVE

  @@map("stock_movement_type")
}

enum OrderStatus {
  DRAFT
  COMPLETED
  VOID

  @@map("order_status")
}

enum OrderChannel {
  IN_PERSON
  WHATSAPP
  ONLINE

  @@map("order_channel")
}

enum PaymentState {
  PAID
  UNPAID

  @@map("payment_state")
}

enum FulfilmentStatus {
  PENDING
  FULFILLED
  PARTIALLY_FULFILLED
  CANCELLED

  @@map("fulfilment_status")
}

enum SyncOpStatus {
  APPLIED
  DUPLICATE
  CONFLICT
  REJECTED

  @@map("sync_op_status")
}

model Product {
  id                 String        @id @default(cuid()) @map("id")
  businessId         String        @map("business_id")
  clientId           String        @map("client_id")
  name               String        @map("name")
  sellPriceCents     Int           @map("sell_price_cents")
  costPriceCents     Int?          @map("cost_price_cents")
  imageUrl           String?       @map("image_url")
  imageKey           String?       @map("image_key")
  lowStockThreshold  Int?          @map("low_stock_threshold")
  status             ProductStatus @default(ACTIVE) @map("status")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  business       Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  stockMovements StockMovement[]
  orderLines     OrderLine[]

  @@unique([businessId, clientId])
  @@map("products")
}

model StockMovement {
  id         String            @id @default(cuid()) @map("id")
  businessId String            @map("business_id")
  clientId   String            @map("client_id")
  productId  String            @map("product_id")
  type       StockMovementType @map("type")
  qtyDelta   Int               @map("qty_delta")
  reason     String?           @map("reason")
  orderId    String?           @map("order_id")
  occurredAt DateTime          @map("occurred_at")
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  order    Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@unique([businessId, clientId])
  @@map("stock_movements")
}

model Order {
  id               String           @id @default(cuid()) @map("id")
  businessId       String           @map("business_id")
  clientId         String           @map("client_id")
  orderNumber      String           @map("order_number")
  customerId       String?          @map("customer_id")
  status           OrderStatus      @default(DRAFT) @map("status")
  channel          OrderChannel     @default(IN_PERSON) @map("channel")
  paymentState     PaymentState     @default(PAID) @map("payment_state")
  subtotalCents    Int              @map("subtotal_cents")
  totalCents       Int              @map("total_cents")
  fulfilmentStatus FulfilmentStatus? @map("fulfilment_status")
  paymentRef       String?          @map("payment_ref")
  escrowRef        String?          @map("escrow_ref")
  occurredAt       DateTime         @map("occurred_at")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  business       Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer       Customer?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  lines          OrderLine[]
  stockMovements StockMovement[]

  @@unique([businessId, clientId])
  @@unique([businessId, orderNumber])
  @@map("orders")
}

model OrderLine {
  id             String  @id @default(cuid()) @map("id")
  businessId     String  @map("business_id")
  orderId        String  @map("order_id")
  productId      String? @map("product_id")
  nameSnapshot   String  @map("name_snapshot")
  unitPriceCents Int     @map("unit_price_cents")
  qty            Int     @map("qty")
  lineTotalCents Int     @map("line_total_cents")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product  Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@map("order_lines")
}

model Customer {
  id         String   @id @default(cuid()) @map("id")
  businessId String   @map("business_id")
  clientId   String   @map("client_id")
  name       String   @map("name")
  phone      String?  @map("phone")
  email      String?  @map("email")
  consentId  String?  @map("consent_id")
  notes      String?  @map("notes")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  consent  Consent? @relation(fields: [consentId], references: [id], onDelete: SetNull)
  orders   Order[]

  @@unique([businessId, clientId])
  @@map("customers")
}

model AnalyticsEvent {
  id         String   @id @default(cuid()) @map("id")
  businessId String?  @map("business_id")
  event      String   @map("event")
  properties Json?    @map("properties")
  distinctId String   @map("distinct_id")
  source     String   @map("source")
  occurredAt DateTime @map("occurred_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  business Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)

  @@map("analytics_events")
}
